#! /bin/bash

JJ_ROOT=$(jj root 2>/dev/null)
if [[ -z "$JJ_ROOT" || "$JJ_ROOT" != "$BUILD_BASE/source"* ]]; then
  BUILD_SOURCE="$BUILD_BASE/source/trunk"
else
  BUILD_SOURCE=$JJ_ROOT
fi

SETTING=$1
VALUE=$2

. $BUILD_BASE/bin/defaults

eval "DEFAULT=\$${SETTING}_DEFAULT"

if [ -n "$VALUE" ]; then
  if [ "$SETTING" == "BUILD_LEVEL" ]; then
    if [ ! -f "$BUILD_BASE/config/levels/${VALUE}.mozconfig" ]; then
      echo "Unknown build level ${VALUE}"
      exit 1
    fi
  elif [ "$SETTING" == "BUILD_TYPE" ]; then
    if [ ! -f "$BUILD_BASE/config/types/${VALUE}.mozconfig" ]; then
      echo "Unknown build type ${VALUE}"
      exit 1
    fi
  fi
fi

if [ -f "$BUILD_SOURCE/.env" ]; then
  sed -i "/$SETTING=/d" $BUILD_SOURCE/.env
fi

if [ -n "$VALUE" -a "$VALUE" != "$DEFAULT" ]; then
  echo "$SETTING=\"$VALUE\"" >> $BUILD_SOURCE/.env
fi
